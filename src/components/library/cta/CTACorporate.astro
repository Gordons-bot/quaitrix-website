---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
}
const {
  title = 'Start your project today',
  description = 'Our team is ready to help you build a reliable digital presence.',
  ctaText = 'Schedule a call',
  ctaHref = '#contact',
} = Astro.props;
---

<section class="bg-slate-50 py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-8 rounded-md border border-slate-300 bg-white p-10 shadow-md sm:flex-row"
    >
      <div>
        <h2 class="text-2xl font-serif tracking-tight text-slate-800">{title}</h2>
        <p class="mt-2 text-slate-600">{description}</p>
      </div>
      <a
        href={ctaHref}
        class="rounded-md bg-blue-700 px-5 py-3 text-sm font-semibold text-white shadow-md hover:bg-blue-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700"
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
