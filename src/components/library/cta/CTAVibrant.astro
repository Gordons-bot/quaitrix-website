---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
}
const {
  title = 'Let’s make something bold',
  description = 'Vibrant experiences that convert visitors into fans.',
  ctaText = 'Get in touch',
  ctaHref = '#contact',
} = Astro.props;
---

<section class="bg-white py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="mx-auto flex max-w-5xl flex-col items-center justify-between gap-8 rounded-2xl border border-pink-200 bg-white p-10 shadow-xl sm:flex-row"
    >
      <div>
        <h2 class="text-2xl font-bold tracking-wide text-slate-900">{title}</h2>
        <p class="mt-2 text-slate-900">{description}</p>
      </div>
      <a
        href={ctaHref}
        class="rounded-full bg-pink-500 px-6 py-3 text-sm font-bold text-white shadow-xl hover:bg-pink-600 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pink-500"
      >
        {ctaText}
      </a>
    </div>
  </div>
</section>
