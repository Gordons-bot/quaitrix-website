---
interface Props {
  title?: string;
  description?: string;
  items?: Array<{ heading: string; body: string }>;
}
const {
  title = 'Our services',
  description = 'Trusted solutions for businesses that demand reliability and clarity.',
  items = [
    { heading: 'Strategy', body: 'Research-driven planning to align technology with business goals.' },
    { heading: 'Development', body: 'Robust engineering with modern frameworks and security-first practices.' },
    { heading: 'Support', body: 'Ongoing maintenance and optimization to keep systems performing.' },
  ],
} = Astro.props;
---
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-serif tracking-tight text-slate-800 sm:text-4xl">
        {title}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        {description}
      </p>
    </div>
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {items.map(({ heading, body }) => (
        <div class="rounded-md border border-slate-300 bg-white p-8 shadow-md">
          <h3 class="text-lg font-semibold text-slate-800">{heading}</h3>
          <p class="mt-3 text-slate-600">{body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
