---
interface Props {
  title?: string;
  description?: string;
  items?: Array<{ heading: string; body: string }>;
}
const {
  title = 'RAW CAPABILITIES',
  description = 'No polish. No compromise. Just structure and intent.',
  items = [
    { heading: 'BLOCK', body: 'Unapologetic layout primitives without decoration.' },
    { heading: 'BOLD', body: 'Hard edges, loud spacing, zero ambiguity.' },
    { heading: 'BRUTAL', body: 'Utility over beauty, function over form.' },
  ],
} = Astro.props;
---

<section class="bg-slate-900 py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-mono uppercase tracking-widest text-amber-50 sm:text-4xl">
        {title}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-amber-50">
        {description}
      </p>
    </div>
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map(({ heading, body }) => (
          <div class="rounded-none border-2 border-slate-900 bg-amber-50 p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
            <h3 class="text-lg font-bold uppercase tracking-widest text-slate-900">{heading}</h3>
            <p class="mt-3 text-slate-900">{body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
