---
interface Props {
  title?: string;
  description?: string;
  items?: Array<{ heading: string; body: string }>;
}
const {
  title = 'Built for performance',
  description = 'We focus on what matters most — speed, accessibility, and clean code.',
  items = [
    { heading: 'Fast', body: 'Optimized assets and minimal JavaScript for instant loads.' },
    { heading: 'Accessible', body: 'Semantic HTML, keyboard navigation, and proper contrast.' },
    { heading: 'Maintainable', body: 'Clear component boundaries so changes stay predictable.' },
  ],
} = Astro.props;
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {title}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        {description}
      </p>
    </div>
    <div class="mx-auto mt-16 grid max-w-7xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map(({ heading, body }) => (
          <div class="rounded-xl border border-slate-200 bg-white p-8 shadow-sm h-full">
            <h3 class="text-lg font-semibold text-slate-900">{heading}</h3>
            <p class="mt-3 text-slate-600">{body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
