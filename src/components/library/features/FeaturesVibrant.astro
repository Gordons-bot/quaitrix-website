---
interface Props {
  title?: string;
  description?: string;
  items?: Array<{ heading: string; body: string }>;
}
const {
  title = 'What we deliver',
  description = 'High-impact solutions wrapped in vibrant, memorable experiences.',
  items = [
    { heading: 'Design', body: 'Bold visual systems that feel alive and memorable.' },
    { heading: 'Engineering', body: 'Performant code that scales across every interaction.' },
    { heading: 'Growth', body: 'Launch campaigns designed to drive measurable results.' },
  ],
} = Astro.props;
---

<section class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold tracking-wide text-slate-900 sm:text-4xl">
        {title}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-900">
        {description}
      </p>
    </div>
    <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map(({ heading, body }) => (
          <div class="rounded-2xl border border-transparent bg-white p-8 shadow-xl">
            <h3 class="text-lg font-bold text-slate-900">{heading}</h3>
            <p class="mt-3 text-slate-900">{body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
