---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
}
const {
  title = 'Enterprise-grade digital presence',
  description = 'Structured, trustworthy websites designed for scale — built with modern tooling and professional standards.',
  ctaText = 'Start your project',
  ctaHref = '#contact',
} = Astro.props;
---
<section class="bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-serif tracking-tight text-slate-800 sm:text-5xl">
        {title}
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        {description}
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a
          href={ctaHref}
          class="rounded-md bg-blue-700 px-5 py-3 text-sm font-semibold text-white shadow-md hover:bg-blue-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-700"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</section>
