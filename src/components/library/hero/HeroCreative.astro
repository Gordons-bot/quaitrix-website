---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
}
const {
  title = 'Brutally honest design',
  description = 'No fluff. No gradients. Just raw typography, thick borders, and hard shadows.',
  ctaText = 'Enter the void',
  ctaHref = '#contact',
} = Astro.props;
---

<section class="bg-amber-50">
  <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-mono uppercase tracking-widest text-slate-900 sm:text-5xl">
        {title}
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-900">
        {description}
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a
          href={ctaHref}
          class="rounded-none border-2 border-slate-900 bg-amber-400 px-5 py-3 text-sm font-bold uppercase tracking-widest text-slate-900 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:bg-amber-300"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</section>
