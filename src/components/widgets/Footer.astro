---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

interface Props {
  links?: Array<Links>;
  secondaryLinks?: Array<Link>;
  socialLinks?: Array<Link>;
  footNote?: string;
  theme?: string;
  companyDescription?: string;
  contactEmail?: string;
}

const {
  socialLinks = [],
  links = [],
  footNote = '',
  companyDescription = '',
  contactEmail = 'contact@quaitrix.com',
} = Astro.props;
const mailtoHref = 'mailto:' + contactEmail;
---

<footer class="relative bg-slate-950 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-5 sm:px-8 py-12 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 md:gap-8">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a class="inline-block font-bold text-xl text-white mb-3" href={getHomePermalink()}>{SITE?.name}</a>
        <p class="text-sm sm:text-base text-slate-400 leading-relaxed mb-4 max-w-xs">
          {companyDescription}
        </p>
        <a href={mailtoHref} class="text-sm sm:text-base text-indigo-400 hover:text-indigo-300 transition-colors">{contactEmail}</a>
      </div>

      <!-- Link Columns -->
      {
        links.map((section) => (
          <div>
            <h4 class="text-white font-semibold text-sm sm:text-base mb-4">{section.title}</h4>
            {section.links && section.links.length > 0 && (
              <ul class="space-y-3 list-none pl-0">
                {section.links.map((link) => (
                  <li>
                    <a
                      class="text-slate-400 hover:text-white text-sm sm:text-base transition-colors"
                      href={link.href}
                      aria-label={link.ariaLabel}
                    >
                      <span set:html={link.text} />
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
      {
        socialLinks.length > 0 && (
          <ul class="flex gap-4 list-none pl-0">
            {socialLinks.map((link) => (
              <li>
                <a
                  class="flex items-center justify-center w-10 h-10 rounded-lg bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white transition-all"
                  aria-label={link.ariaLabel}
                  href={link.href}
                >
                  {link.icon && <Icon name={link.icon} class="w-5 h-5" />}
                  <span set:html={link.text} />
                </a>
              </li>
            ))}
          </ul>
        )
      }
      <p class="text-base sm:text-base text-slate-400">
        <span set:html={footNote} />
      </p>
    </div>
  </div>
</footer>
