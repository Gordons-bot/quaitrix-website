---
// DemoLayout.astro — Minimal layout for demo preview pages
// FROZEN TEMPLATE — Do not modify without PR + human review
interface Props {
  title?: string;
  businessName?: string;
}

const { title = 'Demo — Quaitrix' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-white antialiased">
    <!-- Minimal demo banner -->
    <div class="bg-indigo-600 text-white text-center text-sm py-2 px-4">
      <span class="font-medium">Demo Preview</span>
      <span class="opacity-75 ml-2">— This is a prototype generated by Quaitrix</span>
    </div>

    <main>
      <slot />
    </main>
  </body>
</html>
