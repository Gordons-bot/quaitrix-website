---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'About Us',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText tagline="About Us" title="We Build Digital Tools for Small Businesses" />

  <!-- Who We Are -->
  <section class="py-20 px-6 sm:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-6">A Small Studio. Big Focus.</h2>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed mb-4">
            Quaitrix is a Mauritius-based web and app studio. We help small businesses get online with clean, fast, personalized websites and mobile apps — without the agency price tag.
          </p>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed mb-4">
            Our process is simple: we build a free demo of your project first. You see exactly what you're getting before you pay a cent. No templates, no shortcuts — just work tailored to your business.
          </p>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            We're not a massive agency. We're a focused team that takes on a limited number of projects so every client gets real attention.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="p-6 rounded-2xl bg-blue-50 dark:bg-slate-800 border border-blue-100 dark:border-slate-700 text-center">
            <div class="text-3xl font-extrabold text-blue-600">100%</div>
            <div class="mt-1 text-sm text-gray-500 dark:text-slate-400">Personalized demos</div>
          </div>
          <div class="p-6 rounded-2xl bg-emerald-50 dark:bg-slate-800 border border-emerald-100 dark:border-slate-700 text-center">
            <div class="text-3xl font-extrabold text-emerald-600">3</div>
            <div class="mt-1 text-sm text-gray-500 dark:text-slate-400">Free revision rounds</div>
          </div>
          <div class="p-6 rounded-2xl bg-violet-50 dark:bg-slate-800 border border-violet-100 dark:border-slate-700 text-center">
            <div class="text-3xl font-extrabold text-violet-600">~15min</div>
            <div class="mt-1 text-sm text-gray-500 dark:text-slate-400">Demo turnaround</div>
          </div>
          <div class="p-6 rounded-2xl bg-amber-50 dark:bg-slate-800 border border-amber-100 dark:border-slate-700 text-center">
            <div class="text-3xl font-extrabold text-amber-600">0</div>
            <div class="mt-1 text-sm text-gray-500 dark:text-slate-400">Upfront payment</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="py-20 px-6 sm:px-8 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-10 text-center">What We Do</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700">
          <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Custom Websites</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">Built from scratch for your business. No templates, no page builders — just clean code that loads fast and works everywhere.</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Mobile Apps</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">Android and iOS apps from a single codebase. We handle everything from development to Play Store submission.</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700">
          <div class="w-12 h-12 rounded-xl bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Integrations</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">Payment gateways, booking systems, CRM connections — we connect your tools so they work together.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Approach -->
  <section class="py-20 px-6 sm:px-8">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-10 text-center">How We Work</h2>
      <div class="space-y-8">
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold">1</div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">You Tell Us What You Need</h3>
            <p class="text-gray-500 dark:text-slate-400 mt-1">Use our chat widget or contact form. Share your business goals, design preferences, and any reference sites you like.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold">2</div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">We Build a Free Demo</h3>
            <p class="text-gray-500 dark:text-slate-400 mt-1">Within about 15 minutes, you get a working preview of your project. Real content, real design — not a mockup.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="shrink-0 w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold">3</div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">You Review, We Refine</h3>
            <p class="text-gray-500 dark:text-slate-400 mt-1">Up to three rounds of changes at no extra cost. When you're happy, we launch. You only pay for the final product.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 sm:px-8 bg-slate-950">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-4">Want to see what we'd build for you?</h2>
      <p class="text-slate-300 mb-8">Start with a free demo. No commitment, no credit card.</p>
      <a href="/start-project" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl text-white bg-blue-600 hover:bg-blue-700 transition-all">
        Start Your Free Demo
      </a>
    </div>
  </section>
</Layout>
