---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Check Your Demo Status — Quaitrix',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <div class="max-w-xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900">Check Your Demo Status</h1>
      <p class="mt-4 text-gray-600">Enter your Customer ID and Order ID to access your demo.</p>
    </div>

    <form id="checkForm" class="bg-white rounded-2xl shadow-lg p-8 border border-gray-200">
      <div class="space-y-6">
        <div>
          <label for="customer_id" class="block text-sm font-medium text-gray-700 mb-2">Customer ID</label>
          <input
            type="text"
            id="customer_id"
            required
            placeholder="CUS-XXXXXX"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm font-mono uppercase"
          />
        </div>

        <div>
          <label for="order_id" class="block text-sm font-medium text-gray-700 mb-2">Order ID</label>
          <input
            type="text"
            id="order_id"
            required
            placeholder="ORD-YYYYMMDD-XXXX"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm font-mono uppercase"
          />
        </div>

        <button
          type="submit"
          id="submitBtn"
          class="w-full px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Check Demo Status
        </button>
      </div>

      <div id="result" class="mt-6 hidden"></div>
    </form>

    <p class="mt-6 text-center text-sm text-gray-500">
      Don't have your IDs? Check your email or chat history — they were sent after verification.
    </p>
  </div>

  <script>
    document.getElementById('checkForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const customer_id = document.getElementById('customer_id').value.trim().toUpperCase();
      const order_id = document.getElementById('order_id').value.trim().toUpperCase();
      const resultDiv = document.getElementById('result');
      const submitBtn = document.getElementById('submitBtn');

      submitBtn.disabled = true;
      submitBtn.textContent = 'Checking...';
      resultDiv.classList.add('hidden');

      try {
        const res = await fetch('/api/demo/check-status', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ customer_id, order_id }),
        });
        const data = await res.json();

        resultDiv.classList.remove('hidden');

        if (!data.found) {
          resultDiv.innerHTML =
            '<div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg text-yellow-800 text-sm"><strong>No demo found.</strong> ' +
            (data.message || 'Please check your IDs and try again.') +
            '</div>';
        } else if (data.expired) {
          resultDiv.innerHTML =
            '<div class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm"><strong>Demo expired.</strong> ' +
            (data.message || 'Your demo has expired. Contact us for a new one.') +
            '</div>';
        } else if (data.status === 'ready') {
          resultDiv.innerHTML =
            '<div class="p-4 bg-green-50 border border-green-200 rounded-lg"><p class="text-green-800 font-semibold text-sm">Your demo is ready!</p><a href="' +
            data.demo_url +
            '" target="_blank" class="mt-2 inline-block px-6 py-2 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 text-sm">View Demo</a>' +
            (data.free_rounds_remaining != null
              ? '<p class="mt-2 text-xs text-green-700">' +
                data.free_rounds_remaining +
                ' free modification rounds remaining.</p>'
              : '') +
            '</div>';
        } else if (data.status === 'building' || data.status === 'modifying') {
          resultDiv.innerHTML =
            '<div class="p-4 bg-blue-50 border border-blue-200 rounded-lg text-blue-800 text-sm"><strong>Demo is ' +
            data.status +
            "...</strong> Check back in a few minutes. You will also receive an email when it's ready.</p></div>";
        } else {
          resultDiv.innerHTML =
            '<div class="p-4 bg-gray-50 border border-gray-200 rounded-lg text-gray-800 text-sm">Status: <strong>' +
            data.status +
            '</strong></div>';
        }
      } catch (_err) {
        resultDiv.classList.remove('hidden');
        resultDiv.innerHTML =
          '<div class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-800 text-sm"><strong>Connection error.</strong> Please try again later.</div>';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Check Demo Status';
      }
    });
  </script>
</Layout>
