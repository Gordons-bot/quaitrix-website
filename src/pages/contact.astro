---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact Us',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <HeroText tagline="Contact" title="Get in Touch" />

  <!-- Contact Form -->
  <ContactUs
    id="form"
    title="Send us a message"
    subtitle="Tell us about your project. We'll get back to you within 24 hours."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
      {
        type: 'text',
        name: 'phone',
        label: 'Phone (optional)',
      },
    ]}
    textarea={{
      label: 'Tell us about your project',
    }}
    disclaimer={{
      label:
        'By submitting this form, you agree to the collection of your information. We only use it to respond to your inquiry.',
    }}
    description="We typically respond within 24 hours."
  />

  <!-- Contact Info -->
  <section class="py-20 px-6 sm:px-8 bg-gray-50 dark:bg-slate-900">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 text-center">Reach Us Directly</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 text-center">
          <div class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 dark:text-white mb-1">Email</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm">contact@quaitrix.com</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 text-center">
          <div class="w-12 h-12 rounded-xl bg-emerald-100 dark:bg-emerald-900/30 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 dark:text-white mb-1">Phone / WhatsApp</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm">+230 5711 0755</p>
        </div>
        <div class="p-6 rounded-2xl bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 text-center">
          <div class="w-12 h-12 rounded-xl bg-violet-100 dark:bg-violet-900/30 flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-bold text-gray-900 dark:text-white mb-1">Location</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm">Mauritius</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ-style info -->
  <section class="py-20 px-6 sm:px-8">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 text-center">Common Questions</h2>
      <div class="space-y-6">
        <div class="p-6 rounded-2xl border border-gray-200 dark:border-slate-700">
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">How does the free demo work?</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">You fill out our project form with your business details. We use that to build a personalized preview of your website or app — usually within 15 minutes. You see it before you pay anything.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-200 dark:border-slate-700">
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">What does it cost?</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">We quote based on your project scope after the demo. No hidden fees. You only pay when you're happy with what you see.</p>
        </div>
        <div class="p-6 rounded-2xl border border-gray-200 dark:border-slate-700">
          <h3 class="font-bold text-gray-900 dark:text-white mb-2">Can I request changes?</h3>
          <p class="text-gray-500 dark:text-slate-400 text-sm leading-relaxed">Yes — every project includes up to three rounds of revisions at no extra cost. We want you to be satisfied.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
