---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Quaitrix — We Build Your Website Before You Pay',
  ignoreTitleTemplate: true
};
---

<Layout metadata={metadata}>
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- HERO — Dark premium, high-impact -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen flex items-center justify-center bg-slate-950 overflow-hidden overflow-hidden">
    <!-- Background image layer -->
    <div class="absolute inset-0 opacity-20" style="background-image: url('/hero-bg.jpg'); background-size: cover; background-position: center; background-position: center;"></div>
    <!-- Gradient overlay for readability -->
    <div class="absolute inset-0 bg-gradient-to-b from-slate-950/70 via-slate-950/50 to-slate-950/80"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="relative z-10 max-w-5xl mx-auto px-6 sm:px-8 text-center py-32">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 mb-8">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="text-sm font-medium text-blue-300">Demo-First Development</span>
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold tracking-tight text-white leading-[1.1] text-balance">
        We Build Your Website<br class="hidden sm:block" /> <span class="bg-gradient-to-r from-blue-400 to-violet-400 bg-clip-text text-transparent">Before You Pay</span>
      </h1>
      <p class="mt-8 text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Get a free, personalized demo of your project before committing. No upfront risk — see exactly what you're getting, then decide.
      </p>
      <div class="mt-12 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/start-project" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl bg-blue-600 text-white hover:bg-blue-500 transition-all shadow-lg shadow-blue-600/25 hover:shadow-blue-500/40 hover:scale-[1.02]">
          Start Your Free Demo
          <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl border border-slate-600 text-slate-200 hover:bg-slate-800 hover:border-slate-500 transition-all hover:scale-[1.02]">
          View Our Process
        </a>
      </div>
      <!-- Social proof -->
      <div class="mt-16 flex flex-wrap items-center justify-center gap-8 text-slate-500 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <span>No upfront payment</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <span>15-minute demo turnaround</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <span>Transparent pricing</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- HOW IT WORKS — 3-step process -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section id="how-it-works" class="relative py-24 sm:py-32 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="text-center mb-20">
        <p class="text-sm font-semibold tracking-widest text-blue-600 uppercase mb-3">How It Works</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-gray-900">Three steps to your dream project</h2>
        <p class="mt-5 text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
          No lengthy proposals. No back-and-forth emails. Just a streamlined path from idea to reality.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
        <!-- Step 1 -->
        <div class="relative p-8 rounded-2xl bg-slate-50 border border-slate-100">
          <div class="w-14 h-14 rounded-xl bg-blue-100 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <div class="absolute top-8 right-8 text-5xl font-bold text-slate-100">01</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">Chat & Briefing</h3>
          <p class="text-gray-600 leading-relaxed">Tell us about your project through our chat. Share your vision, goals, and preferences — it takes just 2 minutes.</p>
        </div>

        <!-- Step 2 -->
        <div class="relative p-8 rounded-2xl bg-blue-50 border border-blue-100">
          <div class="w-14 h-14 rounded-xl bg-blue-600 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <div class="absolute top-8 right-8 text-5xl font-bold text-blue-100">02</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">We Build Your Demo</h3>
          <p class="text-gray-600 leading-relaxed">Our team creates a personalized demo of your project. See exactly what you'll get — in about 15 minutes, free.</p>
        </div>

        <!-- Step 3 -->
        <div class="relative p-8 rounded-2xl bg-slate-50 border border-slate-100">
          <div class="w-14 h-14 rounded-xl bg-green-100 flex items-center justify-center mb-6">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="absolute top-8 right-8 text-5xl font-bold text-slate-100">03</div>
          <h3 class="text-xl font-bold text-gray-900 mb-3">You Review & Decide</h3>
          <p class="text-gray-600 leading-relaxed">Love it? We proceed with full development. Not convinced? No pressure — the demo was completely free.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- WHY CHOOSE US — Trust signals -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 sm:py-32 bg-slate-900 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: url('/tech-dark.jpg'); background-size: cover; background-position: center;"></div>
    <div class="absolute inset-0 bg-slate-900/85"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8">
      <div class="text-center mb-20">
        <p class="text-sm font-semibold tracking-widest text-blue-400 uppercase mb-3">Why Choose Quaitrix</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white">Zero upfront risk, total transparency</h2>
        <p class="mt-5 text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
          We believe in earning your trust through results, not promises.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-lg bg-green-500/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Zero Upfront Risk</h3>
          <p class="text-slate-400 leading-relaxed text-sm">Get a working demo before paying a single cent. You see exactly what you're investing in.</p>
        </div>

        <div class="p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-lg bg-blue-500/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">15-Minute Turnaround</h3>
          <p class="text-slate-400 leading-relaxed text-sm">Our AI-assisted workflow generates your personalized demo in minutes, not days or weeks.</p>
        </div>

        <div class="p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-lg bg-violet-500/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-violet-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Transparent Pricing</h3>
          <p class="text-slate-400 leading-relaxed text-sm">Clear, upfront pricing tiers. No hidden fees, no surprise invoices. You know the cost before we start.</p>
        </div>

        <div class="p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-lg bg-amber-500/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Dedicated Expert Team</h3>
          <p class="text-slate-400 leading-relaxed text-sm">Senior developers and designers only — no juniors, no outsourcing. Direct communication with your team.</p>
        </div>

        <div class="p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-lg bg-rose-500/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-rose-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">3 Free Revisions</h3>
          <p class="text-slate-400 leading-relaxed text-sm">Not perfect yet? We refine your project up to three times at no extra cost. Your satisfaction is guaranteed.</p>
        </div>

        <div class="p-8 rounded-2xl bg-slate-800/50 border border-slate-700/50 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Post-Launch Support</h3>
          <p class="text-slate-400 leading-relaxed text-sm">We don't disappear after delivery. Ongoing maintenance, updates, and optimization — always included.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <!-- PRICING TIERS -->
  <!-- ═══════════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 sm:py-32 bg-slate-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="text-center mb-20">
        <p class="text-sm font-semibold tracking-widest text-blue-600 uppercase mb-3">Pricing</p>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-gray-900">Simple, transparent pricing</h2>
        <p class="mt-5 text-lg text-gray-600 max-w-2xl mx-auto leading-relaxed">
          No hidden fees. No surprises. Choose the tier that fits your needs.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <!-- Basic -->
        <div class="w-full bg-white rounded-2xl shadow-sm p-8 border border-gray-200 flex flex-col">
          <h3 class="text-xl font-bold text-gray-900">Basic Website</h3>
          <div class="mt-4 flex items-baseline">
            <span class="text-4xl font-extrabold text-gray-900">$1,500</span>
          </div>
          <p class="mt-2 text-sm text-gray-500">3–7 days delivery</p>
          <ul class="mt-6 space-y-3 flex-1">
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              1–5 page responsive website
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Mobile-first design
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              SEO optimization
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Contact form with validation
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Core Web Vitals optimized
            </li>
          </ul>
          <a href="/start-project" class="mt-8 block text-center px-6 py-3 rounded-xl border-2 border-blue-600 text-blue-600 font-semibold hover:bg-blue-50 transition-colors">
            Get Started
          </a>
        </div>

        <!-- Standard (highlighted) -->
        <div class="w-full bg-white rounded-2xl shadow-xl p-8 border-2 border-blue-600 flex flex-col relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-blue-600 text-white text-xs font-bold rounded-full uppercase tracking-wide">Most Popular</div>
          <h3 class="text-xl font-bold text-gray-900">Standard Website</h3>
          <div class="mt-4 flex items-baseline">
            <span class="text-4xl font-extrabold text-gray-900">$5,000</span>
          </div>
          <p class="mt-2 text-sm text-gray-500">1–3 weeks delivery</p>
          <ul class="mt-6 space-y-3 flex-1">
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Everything in Basic, plus:
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Custom design &amp; branding
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              CMS integration
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Scroll-driven animations
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Analytics setup
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Chatbot / AI assistant
            </li>
          </ul>
          <a href="/start-project" class="mt-8 block text-center px-6 py-3 rounded-xl bg-blue-600 text-white font-semibold hover:bg-blue-700 transition-colors">
            Get Started
          </a>
        </div>

        <!-- Premium -->
        <div class="w-full bg-white rounded-2xl shadow-sm p-8 border border-gray-200 flex flex-col">
          <h3 class="text-xl font-bold text-gray-900">Premium Full-Stack</h3>
          <div class="mt-4 flex items-baseline">
            <span class="text-4xl font-extrabold text-gray-900">$15,000+</span>
          </div>
          <p class="mt-2 text-sm text-gray-500">3–8 weeks delivery</p>
          <ul class="mt-6 space-y-3 flex-1">
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Everything in Standard, plus:
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Full-stack application
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Database &amp; authentication
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              E-commerce / payments
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              CI/CD pipeline &amp; DevOps
            </li>
            <li class="flex items-start gap-3 text-sm text-gray-600">
              <svg class="w-5 h-5 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Ongoing maintenance &amp; support
            </li>
          </ul>
          <a href="/start-project" class="mt-8 block text-center px-6 py-3 rounded-xl border-2 border-blue-600 text-blue-600 font-semibold hover:bg-blue-50 transition-colors">
            Get Started
          </a>
        </div>
      </div>

      <!-- Add-ons -->
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mt-16">
