---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services — Quaitrix Web & Android Development',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- HERO — Dark premium -->
  <section class="relative py-32 bg-slate-950 overflow-hidden">
    <div
      class="absolute inset-0 opacity-15"
      style="background-image: url('/hero-bg.jpg'); background-size: cover; background-position: center;"
    >
    </div>
    <div class="absolute inset-0 bg-gradient-to-b from-slate-950/60 to-slate-950/80"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white">Our Services</h1>
      <p class="mt-6 text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto leading-relaxed">
        Professional web and Android app development — delivered by our expert team with modern tools and proven
        processes.
      </p>
    </div>
  </section>

  <!-- OUR PROCESS -->
  <section class="relative py-24 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 text-center mb-16">Our Process</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-8">
        <div class="text-center">
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg"
          >
            1
          </div>
          <h3 class="font-semibold text-gray-900">Discovery</h3>
          <p class="mt-2 text-sm text-gray-600">We learn about your business, goals, and requirements.</p>
        </div>
        <div class="text-center">
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg"
          >
            2
          </div>
          <h3 class="font-semibold text-gray-900">Design</h3>
          <p class="mt-2 text-sm text-gray-600">Wireframes, mockups, and visual direction — your approval.</p>
        </div>
        <div class="text-center">
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg"
          >
            3
          </div>
          <h3 class="font-semibold text-gray-900">Development</h3>
          <p class="mt-2 text-sm text-gray-600">Our developers build with clean, maintainable code.</p>
        </div>
        <div class="text-center">
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg"
          >
            4
          </div>
          <h3 class="font-semibold text-gray-900">QA &amp; Testing</h3>
          <p class="mt-2 text-sm text-gray-600">Rigorous testing across devices and browsers.</p>
        </div>
        <div class="text-center">
          <div
            class="w-12 h-12 mx-auto mb-4 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-lg"
          >
            5
          </div>
          <h3 class="font-semibold text-gray-900">Launch</h3>
          <p class="mt-2 text-sm text-gray-600">Deployment, monitoring, and ongoing support.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WEBSITES — Dark -->
  <section class="relative py-24 overflow-hidden">
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: url('/tech-dark.jpg'); background-size: cover; background-position: center;"
    >
    </div>
    <div class="absolute inset-0 bg-slate-900/85"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-sm font-semibold text-blue-400 uppercase tracking-wide">Web Development</span>
          <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-white">Custom Websites</h2>
          <p class="mt-4 text-lg text-slate-300 leading-relaxed">
            Our developers build fast, modern, SEO-optimized websites using the latest frameworks. Every site is
            mobile-first, Core Web Vitals optimized, and designed to convert.
          </p>
          <div class="mt-8 grid sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-white">Tech Stack</h3>
              <ul class="mt-3 space-y-2 text-sm text-slate-400">
                <li>Next.js / Astro / React</li>
                <li>Tailwind CSS v4</li>
                <li>TypeScript</li>
                <li>Node.js APIs</li>
              </ul>
            </div>
            <div>
              <h3 class="font-semibold text-white">Features</h3>
              <ul class="mt-3 space-y-2 text-sm text-slate-400">
                <li>Mobile-first responsive</li>
                <li>SEO meta tags &amp; sitemap</li>
                <li>Core Web Vitals optimized</li>
                <li>Dark mode support</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="relative">
          <div class="aspect-video bg-slate-800 rounded-2xl overflow-hidden shadow-2xl border border-slate-700/50">
            <img
              src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Website on laptop"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ANDROID — Light -->
  <section class="relative py-24 bg-slate-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 sm:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="aspect-video bg-gray-200 rounded-2xl overflow-hidden shadow-lg">
            <img
              src="https://images.unsplash.com/photo-1512941937669-90a1b58e7e9c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
              alt="Android phone showing app"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <span class="text-sm font-semibold text-blue-600 uppercase tracking-wide">Mobile Development</span>
          <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-gray-900">Native Android Apps</h2>
          <p class="mt-4 text-lg text-gray-600 leading-relaxed">
            Our mobile developers build production-ready Android apps with Kotlin and Jetpack Compose. Offline-first
            architecture, clean MVVM pattern, and Material Design 3 UI.
          </p>
          <div class="mt-8 grid sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-gray-900">Tech Stack</h3>
              <ul class="mt-3 space-y-2 text-sm text-gray-600">
                <li>Kotlin</li>
                <li>Jetpack Compose (Material 3)</li>
                <li>Hilt dependency injection</li>
                <li>Room local database</li>
              </ul>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900">Capabilities</h3>
              <ul class="mt-3 space-y-2 text-sm text-gray-600">
                <li>Offline-first data layer</li>
                <li>Push notifications</li>
                <li>Play Store submission</li>
                <li>CI/CD build pipelines</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING — Dark -->
  <section class="relative py-24 overflow-hidden">
    <div
      class="absolute inset-0 opacity-10"
      style="background-image: url('/tech-dark.jpg'); background-size: cover; background-position: center;"
    >
    </div>
    <div class="absolute inset-0 bg-slate-900/85"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-8">
      <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-4">Pricing</h2>
      <p class="text-center text-slate-400 mb-16 max-w-2xl mx-auto">
        Transparent packages. Choose the tier that fits your project.
      </p>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="w-full bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900">Basic</h3>
          <div class="mt-4"><span class="text-4xl font-extrabold text-gray-900">$1,500</span></div>
          <p class="mt-2 text-sm text-gray-500">3–7 days</p>
          <ul class="mt-6 space-y-3 text-sm text-gray-600">
            <li>1–5 page responsive site</li>
            <li>Mobile-first design</li>
            <li>SEO optimization</li>
            <li>Contact form</li>
            <li>Core Web Vitals optimized</li>
          </ul>
          <a
            href="/start-project"
            class="mt-8 block text-center px-6 py-3 rounded-xl border-2 border-blue-600 text-blue-600 font-semibold hover:bg-blue-50 transition-colors"
            >Start</a
          >
        </div>
        <div class="bg-blue-600 rounded-2xl p-8 text-white relative shadow-xl shadow-blue-600/20">
          <div
            class="absolute -top-4 left-1/2 -translate-x-1/2 px-4 py-1 bg-yellow-400 text-gray-900 text-xs font-bold rounded-full uppercase tracking-wide"
          >
            Popular
          </div>
          <h3 class="text-xl font-bold">Standard</h3>
          <div class="mt-4"><span class="text-4xl font-extrabold">$5,000</span></div>
          <p class="mt-2 text-sm text-blue-200">1–3 weeks</p>
          <ul class="mt-6 space-y-3 text-sm text-blue-100">
            <li>Everything in Basic</li>
            <li>Custom design &amp; branding</li>
            <li>CMS integration</li>
            <li>Animations &amp; interactions</li>
            <li>Chatbot / AI assistant</li>
            <li>Analytics setup</li>
          </ul>
          <a
            href="/start-project"
            class="mt-8 block text-center px-6 py-3 rounded-xl bg-white text-blue-600 font-semibold hover:bg-blue-50 transition-colors"
            >Start</a
          >
        </div>
        <div class="w-full bg-white rounded-2xl p-8 border border-gray-200">
          <h3 class="text-xl font-bold text-gray-900">Premium</h3>
          <div class="mt-4"><span class="text-4xl font-extrabold text-gray-900">$15,000+</span></div>
          <p class="mt-2 text-sm text-gray-500">3–8 weeks</p>
          <ul class="mt-6 space-y-3 text-sm text-gray-600">
            <li>Everything in Standard</li>
            <li>Full-stack application</li>
            <li>Database &amp; authentication</li>
            <li>E-commerce / payments</li>
            <li>CI/CD &amp; DevOps</li>
            <li>Ongoing support</li>
          </ul>
          <a
            href="/start-project"
            class="mt-8 block text-center px-6 py-3 rounded-xl border-2 border-blue-600 text-blue-600 font-semibold hover:bg-blue-50 transition-colors"
            >Start</a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-24 bg-gradient-to-br from-blue-600 via-indigo-600 to-violet-700 overflow-hidden">
    <div class="relative z-10 max-w-4xl mx-auto px-6 sm:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-white">Let us discuss your project</h2>
      <p class="mt-6 text-lg text-blue-100 leading-relaxed">
        Send us a brief and our team will respond within 24 hours.
      </p>
      <a
        href="/start-project"
        class="mt-10 inline-flex items-center justify-center px-8 py-4 text-lg font-semibold rounded-xl bg-white text-blue-600 hover:bg-blue-50 transition-all shadow-xl hover:scale-[1.02]"
      >
        Start Your Project
      </a>
    </div>
  </section>
</Layout>
